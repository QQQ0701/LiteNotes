<Window x:Class="LiteNotes.View.NotesWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:vm="clr-namespace:LiteNotes.ViewModel"
        xmlns:converters="clr-namespace:LiteNotes.Converters"
        Icon="/Images/note_icon.ico"
        mc:Ignorable="d"
        d:DataContext="{d:DesignInstance Type=vm:NotesViewModel}"
        WindowStartupLocation="CenterScreen"
        PreviewMouseDown="Window_PreviewMouseDown"
        FontFamily="Microsoft JhengHei UI"
        Title="LiteNotes" Height="680" Width="1200">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="200"/>
            <ColumnDefinition Width="240"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- ═══════════════════════════════════════════════════ -->
        <!-- Row 0：頂部列（橫跨左側兩欄 + 右側編輯區）           -->
        <!-- ═══════════════════════════════════════════════════ -->

        <!-- 左側：漢堡選單 + 搜尋框（橫跨 Column 0-1） -->
        <Border Grid.Row="0" Grid.Column="0" Grid.ColumnSpan="2"
                Background="White"
                BorderBrush="#E8E8E8" BorderThickness="0,0,1,1">
            <Grid Margin="8,6">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- [≡] 漢堡選單 -->
                <Menu Grid.Column="0" Background="Transparent" VerticalAlignment="Center">
                    <MenuItem Padding="6,4" FontSize="13" Cursor="Hand">
                        <MenuItem.Header>
                            <TextBlock Text="≡" FontSize="20" FontWeight="Bold"
                                       Foreground="#555555"/>
                        </MenuItem.Header>

                        <MenuItem Command="{Binding SyncCommand}">
                            <MenuItem.Icon>
                                <TextBlock Text="☁️" FontSize="14" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </MenuItem.Icon>
                            <MenuItem.Header>
                                <TextBlock Text="同步到雲端" Margin="4,2,0,2"/>
                            </MenuItem.Header>
                        </MenuItem>

                        <MenuItem Command="{Binding RestoreFromCloudCommand}">
                            <MenuItem.Icon>
                                <TextBlock Text="⬇️" FontSize="14" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </MenuItem.Icon>
                            <MenuItem.Header>
                                <TextBlock Text="從雲端還原" Margin="4,2,0,2"/>
                            </MenuItem.Header>
                        </MenuItem>

                        <Separator/>

                        <MenuItem Command="{Binding LogoutCommand}">
                            <MenuItem.Icon>
                                <TextBlock Text="🚪" FontSize="14" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </MenuItem.Icon>
                            <MenuItem.Header>
                                <TextBlock Text="登出" Margin="4,2,0,2"/>
                            </MenuItem.Header>
                        </MenuItem>

                    </MenuItem>
                </Menu>

                <!-- 搜尋框 -->
                <TextBox Grid.Column="1"
                         Text="{Binding SearchKeyword, UpdateSourceTrigger=PropertyChanged}"
                         TextChanged="SearchTextBox_TextChanged"
                         FontSize="13" Padding="8,5"
                         Margin="6,0,0,0"
                         BorderThickness="1" BorderBrush="#D0D0D0"
                         Background="#F5F5F5"
                         VerticalContentAlignment="Center">
                    <TextBox.InputBindings>
                        <KeyBinding Key="Return" Command="{Binding SearchCommand}"/>
                        <KeyBinding Key="Escape" Command="{Binding ClearSearchCommand}"/>
                    </TextBox.InputBindings>
                </TextBox>

                <!-- 清除搜尋按鈕 -->
                <Button Grid.Column="2"
                        Command="{Binding ClearSearchCommand}"
                        Content="✕" FontSize="13"
                        Padding="6,4" Margin="4,0,0,0"
                        BorderThickness="0" Background="Transparent"
                        Foreground="#999999" Cursor="Hand"
                        Visibility="{Binding IsSearchMode, Converter={StaticResource BoolToVisibilityConverter}}"/>
            </Grid>
        </Border>

        <!-- 右側：標題列 + 附件按鈕 + 儲存狀態 -->
        <Border Grid.Row="0" Grid.Column="2"
                Background="White"
                BorderBrush="#E8E8E8" BorderThickness="0,0,0,1"
                Padding="16,6">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- 筆記標題 -->
                <TextBox Grid.Column="0"
                         Text="{Binding SelectedNote.Name, UpdateSourceTrigger=PropertyChanged}"
                         GotFocus="TitleTextBox_GotFocus"
                         LostFocus="TitleTextBox_LostFocus"
                         TextChanged="TitleTextBox_TextChanged"
                         FontSize="18" FontWeight="Bold"
                         BorderThickness="0" Padding="0"
                         VerticalContentAlignment="Center"
                         Background="Transparent"
                         Foreground="#1A1A1A"
                         IsEnabled="{Binding SelectedNote, Converter={StaticResource NullToBoolConverter}}"/>

                <!-- 儲存狀態 -->
                <TextBlock Grid.Column="2"
                           Text="{Binding SaveStatus}"
                           FontSize="11" Foreground="#B0B0B0"
                           VerticalAlignment="Center"/>
            </Grid>
        </Border>

        <!-- ═══════════════════════════════════════════════════ -->
        <!-- Row 1：主要內容區                                    -->
        <!-- ═══════════════════════════════════════════════════ -->

        <!-- 左側：筆記本列表 -->
        <Border Grid.Row="1" Grid.Column="0"
                Background="#F7F7F7"
                BorderBrush="#E8E8E8" BorderThickness="0,0,1,0">
            <DockPanel>

                <!-- [+ 筆記本] 按鈕 -->
                <Border DockPanel.Dock="Top"
                        BorderBrush="#E8E8E8" BorderThickness="0,0,0,1"
                        Padding="8,4">
                    <Button Command="{Binding AddNotebookCommand}"
                            Height="32" BorderThickness="0"
                            Background="Transparent"
                            HorizontalContentAlignment="Left"
                            Cursor="Hand">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="＋" FontSize="15"
                                       Foreground="#888888" Margin="4,0,6,0"
                                       VerticalAlignment="Center"/>
                            <TextBlock Text="筆記本" FontSize="13"
                                       Foreground="#888888"
                                       VerticalAlignment="Center"/>
                        </StackPanel>
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border Background="{TemplateBinding Background}"
                                        CornerRadius="6" Padding="8,4">
                                    <ContentPresenter/>
                                </Border>
                            </ControlTemplate>
                        </Button.Template>
                        <Button.Style>
                            <Style TargetType="Button">
                                <Style.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter Property="Background" Value="#EBEBEB"/>
                                    </Trigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                    </Button>
                </Border>

                <!-- 筆記本列表 -->
                <ListView ItemsSource="{Binding Notebooks}"
                          SelectedItem="{Binding SelectedNotebook}"
                          BorderThickness="0" Background="Transparent"
                          ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                          Padding="8,4">

                    <ListView.ItemContainerStyle>
                        <Style TargetType="ListViewItem">
                            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                            <Setter Property="Padding" Value="0"/>
                            <Setter Property="Margin" Value="0,2"/>
                            <Setter Property="Background" Value="Transparent"/>
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="ListViewItem">
                                        <Border Background="{TemplateBinding Background}"
                                                CornerRadius="6" Padding="2">
                                            <ContentPresenter/>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsSelected" Value="True">
                                                <Setter Property="Background" Value="#EBEBEB"/>
                                            </Trigger>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter Property="Background" Value="#F0F0F0"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </ListView.ItemContainerStyle>

                    <ListView.ItemTemplate>
                        <DataTemplate>
                            <Grid Tag="{Binding DataContext, RelativeSource={RelativeSource AncestorType=Window}}">
                                <TextBlock Text="{Binding Name}"
                                           FontSize="14" Padding="8,6"
                                           TextTrimming="CharacterEllipsis"
                                           Foreground="#1A1A1A"
                                           Visibility="{Binding IsEditing, Converter={StaticResource InverseBoolToVisibilityConverter}}"
                                           Tag="{Binding DataContext, RelativeSource={RelativeSource AncestorType=Window}}">
                                    <TextBlock.ContextMenu>
                                        <ContextMenu>
                                            <MenuItem Header="重新命名"
                                                      Command="{Binding PlacementTarget.Tag.EditCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                                      CommandParameter="{Binding PlacementTarget.DataContext, RelativeSource={RelativeSource AncestorType=ContextMenu}}"/>
                                            <MenuItem Header="刪除"
                                                      Command="{Binding PlacementTarget.Tag.DeleteNotebookCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                                      CommandParameter="{Binding PlacementTarget.DataContext, RelativeSource={RelativeSource AncestorType=ContextMenu}}"/>
                                        </ContextMenu>
                                    </TextBlock.ContextMenu>
                                </TextBlock>

                                <TextBox Text="{Binding EditingName, UpdateSourceTrigger=PropertyChanged}"
                                         FontSize="14" Padding="8,6" BorderThickness="0"
                                         Background="White"
                                         Visibility="{Binding IsEditing, Converter={StaticResource BoolToVisibilityConverter}}"
                                         Tag="{Binding DataContext, RelativeSource={RelativeSource AncestorType=Window}}"
                                         LostFocus="NotebookRenameTextBox_LostFocus"
                                         Loaded="AutoSelectTextBox_Loaded"
                                         IsVisibleChanged="AutoSelectTextBox_IsVisibleChanged">
                                    <TextBox.InputBindings>
                                        <KeyBinding Key="Enter"
                                                    Command="{Binding RelativeSource={RelativeSource AncestorType=TextBox}, Path=Tag.ConfirmNotebookRenameCommand}"
                                                    CommandParameter="{Binding}"/>
                                        <KeyBinding Key="Escape"
                                                    Command="{Binding RelativeSource={RelativeSource AncestorType=TextBox}, Path=Tag.CancelNotebookRenameCommand}"
                                                    CommandParameter="{Binding}"/>
                                    </TextBox.InputBindings>
                                </TextBox>
                            </Grid>
                        </DataTemplate>
                    </ListView.ItemTemplate>
                </ListView>
            </DockPanel>
        </Border>

        <!-- 中間：筆記列表 / 搜尋結果（變身區） -->
        <Border Grid.Row="1" Grid.Column="1"
                Background="#FAFAFA"
                BorderBrush="#E8E8E8" BorderThickness="0,0,1,0">
            <Grid>
                <!-- 一般模式：筆記列表 -->
                <DockPanel Visibility="{Binding IsSearchMode, Converter={StaticResource InverseBoolToVisibilityConverter}}">
                    <Border DockPanel.Dock="Top"
                            BorderBrush="#E8E8E8" BorderThickness="0,0,0,1"
                            Padding="8,4">
                        <Button Command="{Binding StartAddNoteCommand}"
                                Height="32" BorderThickness="0"
                                Background="Transparent"
                                HorizontalContentAlignment="Left"
                                Cursor="Hand"
                                IsEnabled="{Binding SelectedNotebook, Converter={StaticResource NullToBoolConverter}}">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="＋" FontSize="15"
                                           Foreground="#888888" Margin="4,0,6,0"
                                           VerticalAlignment="Center"/>
                                <TextBlock Text="New page" FontSize="13"
                                           Foreground="#888888"
                                           VerticalAlignment="Center"/>
                            </StackPanel>
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border Background="{TemplateBinding Background}"
                                            CornerRadius="6" Padding="8,4">
                                        <ContentPresenter/>
                                    </Border>
                                </ControlTemplate>
                            </Button.Template>
                            <Button.Style>
                                <Style TargetType="Button">
                                    <Style.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter Property="Background" Value="#F0F0F0"/>
                                        </Trigger>
                                    </Style.Triggers>
                                </Style>
                            </Button.Style>
                        </Button>
                    </Border>

                    <ListView ItemsSource="{Binding Notes}"
                              SelectedItem="{Binding SelectedNote}"
                              BorderThickness="0" Background="Transparent"
                              ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                              Padding="8,4">
                        <ListView.ItemContainerStyle>
                            <Style TargetType="ListViewItem">
                                <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                                <Setter Property="Padding" Value="0"/>
                                <Setter Property="Margin" Value="0,2"/>
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="ListViewItem">
                                            <Border Background="{TemplateBinding Background}"
                                                    CornerRadius="6" Padding="2">
                                                <ContentPresenter/>
                                            </Border>
                                            <ControlTemplate.Triggers>
                                                <Trigger Property="IsSelected" Value="True">
                                                    <Setter Property="Background" Value="#EBEBEB"/>
                                                </Trigger>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter Property="Background" Value="#F0F0F0"/>
                                                </Trigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                            </Style>
                        </ListView.ItemContainerStyle>
                        <ListView.ItemTemplate>
                            <DataTemplate>
                                <Grid Tag="{Binding DataContext, RelativeSource={RelativeSource AncestorType=Window}}">
                                    <TextBlock Text="{Binding Name}"
                                               FontSize="14" Padding="8,6"
                                               TextTrimming="CharacterEllipsis"
                                               Foreground="#1A1A1A"
                                               Visibility="{Binding IsEditing, Converter={StaticResource InverseBoolToVisibilityConverter}}"
                                               Tag="{Binding DataContext, RelativeSource={RelativeSource AncestorType=Window}}">
                                        <TextBlock.ContextMenu>
                                            <ContextMenu>
                                                <MenuItem Header="刪除"
                                                          Command="{Binding PlacementTarget.Tag.DeleteNoteCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                                          CommandParameter="{Binding PlacementTarget.DataContext, RelativeSource={RelativeSource AncestorType=ContextMenu}}"/>
                                            </ContextMenu>
                                        </TextBlock.ContextMenu>
                                    </TextBlock>

                                    <TextBox Text="{Binding EditingName, UpdateSourceTrigger=PropertyChanged}"
                                             FontSize="14" Padding="8,6" BorderThickness="0"
                                             Background="White"
                                             Visibility="{Binding IsEditing, Converter={StaticResource BoolToVisibilityConverter}}"
                                             Tag="{Binding DataContext, RelativeSource={RelativeSource AncestorType=Window}}"
                                             LostFocus="NoteRenameTextBox_LostFocus"
                                             Loaded="AutoSelectTextBox_Loaded"
                                             IsVisibleChanged="AutoSelectTextBox_IsVisibleChanged">
                                        <TextBox.InputBindings>
                                            <KeyBinding Key="Enter"
                                                        Command="{Binding RelativeSource={RelativeSource AncestorType=TextBox}, Path=Tag.ConfirmNoteRenameCommand}"
                                                        CommandParameter="{Binding}"/>
                                            <KeyBinding Key="Escape"
                                                        Command="{Binding RelativeSource={RelativeSource AncestorType=TextBox}, Path=Tag.CancelNoteRenameCommand}"
                                                        CommandParameter="{Binding}"/>
                                        </TextBox.InputBindings>
                                    </TextBox>
                                </Grid>
                            </DataTemplate>
                        </ListView.ItemTemplate>
                    </ListView>
                </DockPanel>

                <!-- 搜尋模式：搜尋結果 -->
                <DockPanel Visibility="{Binding IsSearchMode, Converter={StaticResource BoolToVisibilityConverter}}">
                    <Border DockPanel.Dock="Top" Padding="12,8"
                            BorderBrush="#E8E8E8" BorderThickness="0,0,0,1">
                        <TextBlock FontSize="13" Foreground="#888888">
                            <Run Text="搜尋結果："/>
                            <Run Text="{Binding SearchResults.Count, Mode=OneWay}"/>
                            <Run Text=" 筆"/>
                        </TextBlock>
                    </Border>

                    <ListView ItemsSource="{Binding SearchResults}"
                              SelectedItem="{Binding SelectedSearchResult}"
                              BorderThickness="0" Background="Transparent"
                              ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                              Padding="8,4">

                        <ListView.ItemContainerStyle>
                            <Style TargetType="ListViewItem">
                                <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                                <Setter Property="Padding" Value="0"/>
                                <Setter Property="Margin" Value="0,2"/>
                                <Setter Property="Background" Value="Transparent"/>
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="ListViewItem">
                                            <Border Background="{TemplateBinding Background}"
                                CornerRadius="6" Padding="4">
                                                <ContentPresenter/>
                                            </Border>

                                            <ControlTemplate.Triggers>
                                                <Trigger Property="IsSelected" Value="True">
                                                    <Setter Property="Background" Value="#EBEBEB"/>
                                                </Trigger>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter Property="Background" Value="#F0F0F0"/>
                                                </Trigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                            </Style>
                        </ListView.ItemContainerStyle>

                        <ListView.ItemTemplate>
                            <DataTemplate>
                                <StackPanel Margin="4,6">
                                    <TextBlock Text="{Binding NoteName}"
                                               FontSize="14" FontWeight="SemiBold"
                                               Foreground="#1A1A1A"
                                               TextTrimming="CharacterEllipsis"/>
                                    <TextBlock Text="{Binding NotebookName}"
                                               FontSize="11" Foreground="#999999"
                                               Margin="0,2,0,0"/>
                                    <TextBlock Text="{Binding MatchSnippet}"
                                               FontSize="12" Foreground="#666666"
                                               TextWrapping="Wrap" MaxHeight="40"
                                               Margin="0,4,0,0"/>
                                </StackPanel>
                            </DataTemplate>
                        </ListView.ItemTemplate>
                    </ListView>
                </DockPanel>
            </Grid>
        </Border>

        <!-- 右側：編輯區 -->
        <Grid Grid.Row="1" Grid.Column="2"
              Background="White" AllowDrop="True" Drop="Grid_Drop">
            <Grid.RowDefinitions>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- 沒選筆記時的引導畫面 -->
            <StackPanel Grid.RowSpan="2"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center"
                        ZIndex="1">
                <StackPanel.Style>
                    <Style TargetType="StackPanel">
                        <Setter Property="Visibility" Value="Collapsed"/>
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding SelectedNote}" Value="{x:Null}">
                                <Setter Property="Visibility" Value="Visible"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </StackPanel.Style>
                <TextBlock Text="📝" FontSize="48"
                           HorizontalAlignment="Center"
                           Margin="0,0,0,16"/>
                <TextBlock Text="選擇一篇筆記開始編輯"
                           FontSize="16" Foreground="#9B9B9B"
                           HorizontalAlignment="Center"/>
            </StackPanel>

            <!-- 筆記內容 -->
            <RichTextBox Grid.Row="0"
                         x:Name="contentRichTextBox"
                         Margin="24,16"
                         FontSize="15"
                         BorderThickness="0"
                         VerticalScrollBarVisibility="Auto"
                         Foreground="#1A1A1A"
                         TextChanged="ContentRichTextBox_TextChanged"
                         IsEnabled="{Binding SelectedNote, Converter={StaticResource NullToBoolConverter}}"
                         AllowDrop="True"
                         PreviewDragOver="ContentRichTextBox_PreviewDragOver"
                         PreviewDrop="ContentRichTextBox_PreviewDrop"/>

            <!-- 附件列表 -->
            <Border Grid.Row="1"
                    BorderBrush="#E8E8E8" BorderThickness="0,1,0,0"
                    Padding="24,8">

                    <Border.Style>
                        <Style TargetType="Border">
                            <Setter Property="Visibility" Value="Visible"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding SelectedNote}" Value="{x:Null}">
                                    <Setter Property="Visibility" Value="Collapsed"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Border.Style>

                    <DockPanel>
                    <Button DockPanel.Dock="Top"
                            Click="UploadButton_Click"
                            HorizontalAlignment="Left"
                            BorderThickness="0"
                            Cursor="Hand"
                            Padding="4" Margin="-4,0,0,8"
                            ToolTip="點擊新增附件"
                            IsEnabled="{Binding SelectedNote, Converter={StaticResource NullToBoolConverter}}">
                        
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border Background="{TemplateBinding Background}"
                                        CornerRadius="4" Padding="{TemplateBinding Padding}">
                                    <ContentPresenter/>
                                </Border>
                            </ControlTemplate>
                        </Button.Template>
                        
                        <Button.Style>
                            <Style TargetType="Button">
                                <Setter Property="Background" Value="Transparent"/>
                                <Style.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter Property="Background" Value="#F0F0F0"/>
                                    </Trigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                        
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="📎" FontSize="13" FontWeight="SemiBold"
                                       Foreground="#888888" VerticalAlignment="Center"/>
                            <TextBlock Text="+" FontSize="14" FontWeight="Bold"
                                       Foreground="#CCCCCC" Margin="6,-2,0,0"
                                       VerticalAlignment="Center"/>
                        </StackPanel>
                        
                    </Button>

                    <ItemsControl ItemsSource="{Binding Attachments}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Padding="8,6" Margin="0,2" CornerRadius="4"
                                        Background="#F7F7F7" Cursor="Hand">
                                    <Border.InputBindings>
                                        <MouseBinding MouseAction="LeftDoubleClick"
                                                      Command="{Binding DataContext.OpenAttachmentCommand,
                                                                RelativeSource={RelativeSource AncestorType=Window}}"
                                                      CommandParameter="{Binding}"/>
                                    </Border.InputBindings>
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>

                                        <TextBlock Grid.Column="0" FontSize="16"
                                                   VerticalAlignment="Center" Margin="0,0,8,0"
                                                   Text="{Binding IsImage,
                                                          Converter={StaticResource BoolToAttachmentIconConverter}}"/>

                                        <TextBlock Grid.Column="1"
                                                   Text="{Binding FileName}"
                                                   FontSize="13" Foreground="#1A1A1A"
                                                   VerticalAlignment="Center"
                                                   TextTrimming="CharacterEllipsis"/>

                                        <TextBlock Grid.Column="2"
                                                   Text="{Binding FileSize,
                                                          Converter={StaticResource FileSizeConverter}}"
                                                   FontSize="12" Foreground="#999999"
                                                   VerticalAlignment="Center" Margin="12,0"/>

                                        <Button Grid.Column="3"
                                                Command="{Binding DataContext.DeleteAttachmentCommand,
                                                          RelativeSource={RelativeSource AncestorType=Window}}"
                                                CommandParameter="{Binding}"
                                                Content="✕" FontSize="12"
                                                Padding="4,2" BorderThickness="0"
                                                Background="Transparent" Foreground="#CCCCCC"
                                                Cursor="Hand"/>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </DockPanel>
            </Border>
        </Grid>

        <!-- ═══════════════════════════════════════════════════ -->
        <!-- Row 2：StatusBar（橫跨左側兩欄）                       -->
        <!-- ═══════════════════════════════════════════════════ -->
        <StatusBar Grid.Row="2" Grid.Column="0" Grid.ColumnSpan="2"
                   Background="#F7F7F7"
                   BorderBrush="#E8E8E8" BorderThickness="0,1,1,0"
                   Height="28">
            <StatusBarItem>
                <TextBlock Text="{Binding StatusMessage}"
                           FontSize="12" Foreground="#1A1A1A"/>
            </StatusBarItem>
        </StatusBar>

    </Grid>
</Window>
