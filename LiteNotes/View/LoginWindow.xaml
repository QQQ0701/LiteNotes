<Window x:Class="LiteNotes.LoginWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:vm="clr-namespace:LiteNotes.ViewModel"
        Icon="/Images/note_icon.ico"
        mc:Ignorable="d"
        WindowStartupLocation="CenterScreen"
        d:DataContext="{d:DesignInstance Type=vm:LoginViewModel}"
        Title="LiteNotes" Height="660" Width="420"
        ResizeMode="NoResize"
        FontFamily="Microsoft JhengHei UI"
        FontSize="14"
        Background="White">
    <Window.Effect>
        <DropShadowEffect BlurRadius="20" Opacity="0.1"
                          ShadowDepth="0" Color="#000000"/>
    </Window.Effect>

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="48,40">

            <!-- ===== 上方 Logo 區 ===== -->
            <StackPanel HorizontalAlignment="Center" Margin="0,0,0,36">
                <Border Background="#F0F4FF" CornerRadius="50"
                        Width="80" Height="80"
                        HorizontalAlignment="Center"
                        Margin="0,0,0,16">

                    <TextBlock Text="🍃"
                           FontSize="44"
                           HorizontalAlignment="Center"
                           Margin="0,0,0,12"/>
                </Border>

                <TextBlock Text="LiteNotes"
                           FontSize="26" FontWeight="Bold"
                           Foreground="#1A1A1A"
                           HorizontalAlignment="Center"
                           Margin="0,0,0,8"/>
                <TextBlock Text="極速檢索，隨時同步你的靈感"
                           FontSize="13" Foreground="#9B9B9B"
                           HorizontalAlignment="Center"/>
            </StackPanel>

            <!-- ===== 錯誤訊息 ===== -->
            <Border Background="#FFF5F5" CornerRadius="6"
                    Padding="12,10" Margin="0,0,0,16"
                    BorderBrush="#FEB2B2" BorderThickness="1">
                <Border.Style>
                    <Style TargetType="Border">
                        <Setter Property="Visibility" Value="Visible"/>
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding ErrorMessage}" Value="">
                                <Setter Property="Visibility" Value="Collapsed"/>
                            </DataTrigger>
                            <DataTrigger Binding="{Binding ErrorMessage}" Value="{x:Null}">
                                <Setter Property="Visibility" Value="Collapsed"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </Border.Style>

                <TextBlock Text="{Binding ErrorMessage}"
                           Foreground="#C53030" FontSize="13"
                           TextWrapping="Wrap"/>


            </Border>

            <!-- ===== 登入模式 ===== -->
            <StackPanel>
                <StackPanel.Style>
                    <Style TargetType="StackPanel">
                        <Setter Property="Visibility" Value="Collapsed"/>
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding IsLoginMode}" Value="True">
                                <Setter Property="Visibility" Value="Visible"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </StackPanel.Style>

                <!-- 電子郵件 -->
                <TextBlock Text="電子郵件" FontSize="13"
                           Foreground="#4A4A4A" Margin="0,0,0,6"/>
                <Border BorderBrush="#E2E2E2" BorderThickness="1"
                        CornerRadius="6" Margin="0,0,0,16">
                    <Grid>
                        <!-- Placeholder 提示文字 -->
                        <TextBlock Text="example@gmail.com"
                                   Foreground="#C8C8C8" FontSize="14"
                                   Margin="12,0,0,0" VerticalAlignment="Center"
                                   IsHitTestVisible="False">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Visibility" Value="Collapsed"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding Email}" Value="">
                                            <Setter Property="Visibility" Value="Visible"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>

                        <TextBox Text="{Binding Email, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                             Height="40" FontSize="14" BorderThickness="0"
                             Padding="12,0" VerticalContentAlignment="Center"
                             Background="Transparent"/>
                    </Grid>
                </Border>

                <!-- 密碼 -->
                <TextBlock Text="密碼" FontSize="13"
                           Foreground="#4A4A4A" Margin="0,0,0,6"/>
                <Border BorderBrush="#E2E2E2" BorderThickness="1"
                        CornerRadius="6" Margin="0,0,0,24">
                    <PasswordBox x:Name="loginPasswordBox"
                                 Height="40" FontSize="14" BorderThickness="0"
                                 Padding="12,0" VerticalContentAlignment="Center"/>
                </Border>

                <!-- 登入按鈕 -->
                <Button Content="登入"
                        Command="{Binding LoginCommand}"
                        Click="LoginButton_Click"
                        Height="42" FontSize="15" FontWeight="SemiBold"
                        Foreground="White" BorderThickness="0"
                        Cursor="Hand" IsDefault="True">

                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border Background="{TemplateBinding Background}"
                    CornerRadius="8"
                    Padding="{TemplateBinding Padding}">
                                <ContentPresenter HorizontalAlignment="Center"
                                  VerticalAlignment="Center"/>
                            </Border>
                        </ControlTemplate>
                    </Button.Template>

                    <Button.Style>
                        <Style TargetType="Button">
                            <Setter Property="Background" Value="#1A1A1A"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsLoading}" Value="True">
                                    <Setter Property="IsEnabled" Value="False"/>
                                    <Setter Property="Background" Value="#9B9B9B"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Button.Style>
                </Button>

                <Button Command="{Binding ForgotPasswordCommand}"
                        Height="32" Margin="0,8,0,0"
                        Background="Transparent" BorderThickness="0"
                        Cursor="Hand"
                        HorizontalAlignment="Right">

                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border Background="{TemplateBinding Background}">
                                <ContentPresenter HorizontalAlignment="Right"
                                  VerticalAlignment="Center"/>
                            </Border>
                        </ControlTemplate>
                    </Button.Template>

                    <Button.Content>
                        <TextBlock FontSize="12" VerticalAlignment="Center">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Foreground" Value="#9B9B9B"/>
                                    <Setter Property="TextDecorations" Value="None"/>
                                    <Style.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter Property="Foreground" Value="#1A1A1A"/>
                                            <Setter Property="TextDecorations" Value="Underline"/>
                                        </Trigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                                 忘記密碼？
                        </TextBlock>
                    </Button.Content>

                </Button>

                <!-- 分隔線 -->
                <Grid Margin="0,20,0,20">
                    <Separator/>
                    <TextBlock Text="或" Background="White"
                               Foreground="#9B9B9B" FontSize="12"
                               HorizontalAlignment="Center" Padding="8,0"/>
                </Grid>

                <!-- 切換到註冊 -->
                <Button Content="建立新帳號"
                        Command="{Binding ToggleModeCommand}"
                        Height="42" FontSize="14"
                        Background="White" Foreground="#1A1A1A"
                        BorderBrush="#E2E2E2" BorderThickness="1"
                        Cursor="Hand"/>

            </StackPanel>

            <!-- ===== 註冊模式 ===== -->
            <StackPanel>
                <StackPanel.Style>
                    <Style TargetType="StackPanel">
                        <Setter Property="Visibility" Value="Collapsed"/>
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding IsLoginMode}" Value="False">
                                <Setter Property="Visibility" Value="Visible"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </StackPanel.Style>

                <!-- 名字 姓氏 並排 -->
                <Grid Margin="0,0,0,16">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="12"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0">
                        <TextBlock Text="名字" FontSize="13"
                                   Foreground="#4A4A4A" Margin="0,0,0,6"/>
                        <Border BorderBrush="#E2E2E2" BorderThickness="1" CornerRadius="6">
                            <TextBox Text="{Binding FirstName, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                     Height="40" FontSize="14" BorderThickness="0"
                                     Padding="12,0" VerticalContentAlignment="Center"
                                     Background="Transparent"/>
                        </Border>
                    </StackPanel>

                    <StackPanel Grid.Column="2">
                        <TextBlock Text="姓氏" FontSize="13"
                                   Foreground="#4A4A4A" Margin="0,0,0,6"/>
                        <Border BorderBrush="#E2E2E2" BorderThickness="1" CornerRadius="6">
                            <TextBox Text="{Binding LastName, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                     Height="40" FontSize="14" BorderThickness="0"
                                     Padding="12,0" VerticalContentAlignment="Center"
                                     Background="Transparent"/>
                        </Border>
                    </StackPanel>
                </Grid>

                <!-- 電子郵件 -->
                <TextBlock Text="電子郵件" FontSize="13"
                           Foreground="#4A4A4A" Margin="0,0,0,6"/>
                <Border BorderBrush="#E2E2E2" BorderThickness="1"
                        CornerRadius="6" Margin="0,0,0,16">
                    <Grid>
                        <!-- Placeholder 提示文字 -->
                        <TextBlock Text="example@gmail.com"
                                   Foreground="#C8C8C8" FontSize="14"
                                   Margin="12,0,0,0" VerticalAlignment="Center"
                                   IsHitTestVisible="False">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Visibility" Value="Collapsed"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding Email}" Value="">
                                            <Setter Property="Visibility" Value="Visible"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                        <TextBox Text="{Binding Email, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                             Height="40" FontSize="14" BorderThickness="0"
                             Padding="12,0" VerticalContentAlignment="Center"
                             Background="Transparent"/>
                    </Grid>
                </Border>

                <!-- 密碼 -->
                <TextBlock Text="密碼" FontSize="13"
                           Foreground="#4A4A4A" Margin="0,0,0,6"/>
                <Border BorderBrush="#E2E2E2" BorderThickness="1"
                        CornerRadius="6" Margin="0,0,0,16">
                    <PasswordBox x:Name="registerPasswordBox"
                                 Height="40" FontSize="14" BorderThickness="0"
                                 Padding="12,0" VerticalContentAlignment="Center"/>
                </Border>

                <!-- 確認密碼 -->
                <TextBlock Text="確認密碼" FontSize="13"
                           Foreground="#4A4A4A" Margin="0,0,0,6"/>
                <Border BorderBrush="#E2E2E2" BorderThickness="1"
                        CornerRadius="6" Margin="0,0,0,24">
                    <PasswordBox x:Name="registerConfirmPasswordBox"
                                 Height="40" FontSize="14" BorderThickness="0"
                                 Padding="12,0" VerticalContentAlignment="Center"/>
                </Border>

                <!-- 註冊按鈕 -->
                <Button Content="建立帳號"
                        Command="{Binding RegisterCommand}"
                        Click="RegisterButton_Click"
                        Height="42" FontSize="15" FontWeight="SemiBold"
                        Foreground="White" BorderThickness="0"
                        Cursor="Hand">
                    <Button.Style>
                        <Style TargetType="Button">
                            <Setter Property="Background" Value="#1A1A1A"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsLoading}" Value="True">
                                    <Setter Property="IsEnabled" Value="False"/>
                                    <Setter Property="Background" Value="#9B9B9B"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Button.Style>
                </Button>

                <!-- 分隔線 -->
                <Grid Margin="0,20,0,20">
                    <Separator/>
                    <TextBlock Text="或" Background="White"
                               Foreground="#9B9B9B" FontSize="12"
                               HorizontalAlignment="Center" Padding="8,0"/>
                </Grid>

                <!-- 切換回登入 -->
                <Button Content="已有帳號，返回登入"
                        Command="{Binding ToggleModeCommand}"
                        Height="42" FontSize="14"
                        Background="White" Foreground="#1A1A1A"
                        BorderBrush="#E2E2E2" BorderThickness="1"
                        Cursor="Hand"/>
            </StackPanel>

        </StackPanel>
    </ScrollViewer>
</Window>