<Window x:Class="StockEvernote.View.NotesWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:vm="clr-namespace:StockEvernote.ViewModel"
        xmlns:converters="clr-namespace:StockEvernote.Converters"
        mc:Ignorable="d"
        d:DataContext="{d:DesignInstance Type=vm:NotesViewModel}"
        WindowStartupLocation="CenterScreen"
        PreviewMouseDown="Window_PreviewMouseDown"
        FontFamily="Microsoft JhengHei UI"
        Title="StockEvernote" Height="680" Width="1200">

    <DockPanel>

        <!-- ===== Menu ===== -->
        <Border DockPanel.Dock="Top"
                Background="White"
                BorderBrush="#E8E8E8"
                BorderThickness="0,0,0,1"
                Height="48">

            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <Menu Grid.Column="0"
                      Background="Transparent"
                      VerticalAlignment="Center"
                      Padding="8,0">
                    <MenuItem Header="📚 筆記本" Padding="8,4">
                        <MenuItem Header="新增筆記本"
                                  Command="{Binding AddNotebookCommand}"
                                  Padding="8,6"/>
                        <Separator/>
                        <MenuItem Header="同步到雲端"
                                  Command="{Binding SyncCommand}"
                                  Padding="8,6"/>
                        <Separator/>
                        <MenuItem Header="從雲端還原"
                                  Command="{Binding RestoreFromCloudCommand}"
                                  Padding="8,6"/>
                        <Separator/>
                        <MenuItem Header="退出"
                                  Click="MenuItem_Click"
                                  Padding="8,6"/>
                    </MenuItem>
                </Menu>

                <!-- 右上角登出按鈕 -->
                <Button Grid.Column="1"
                        Command="{Binding LogoutCommand}"
                        Margin="0,0,16,0"
                        Height="32" Padding="16,0"
                        VerticalAlignment="Center"
                        Cursor="Hand"
                        Foreground="White"
                       BorderThickness="0">
                    <Button.Content>
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="🚪" FontSize="13"
                                       Margin="0,0,6,0"
                                       VerticalAlignment="Center"/>
                            <TextBlock Text="登出" FontSize="13"
                                       VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button.Content>
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border Background="{TemplateBinding Background}"
                                    CornerRadius="6"
                                    Padding="{TemplateBinding Padding}">
                                <ContentPresenter HorizontalAlignment="Center"
                                                  VerticalAlignment="Center"/>
                            </Border>
                        </ControlTemplate>
                    </Button.Template>
                    <Button.Style>
                        <Style TargetType="Button">
                            <Setter Property="Background" Value="#1A1A1A"/>
                            <Style.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter Property="Background" Value="#333333"/>
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </Button.Style>
                </Button>
            </Grid>
        </Border>
        <!-- ===== StatusBar ===== -->
        <StatusBar DockPanel.Dock="Bottom"
                   Background="#F7F7F7"
                   BorderBrush="#E8E8E8" BorderThickness="0,1,0,0"
                   Height="28">
            <StatusBarItem>
                <TextBlock Text="{Binding SyncStatus}"
                           FontSize="12" Foreground="#1A1A1A"/>
            </StatusBarItem>
        </StatusBar>

        <!-- ===== 左側：筆記本列表 ===== -->
        <Border DockPanel.Dock="Left" Width="200"
                Background="#F7F7F7"
                BorderBrush="#E8E8E8" BorderThickness="0,0,1,0">
            <DockPanel>

                <!-- 標題 -->
                <Border DockPanel.Dock="Top"
                        Padding="16,12"
                        BorderBrush="#E8E8E8" BorderThickness="0,0,0,1">
                    <TextBlock Text="筆記本"
                               FontSize="13" FontWeight="SemiBold"
                               Foreground="#888888"/>
                </Border>

                <!-- 筆記本列表 -->
                <ListView ItemsSource="{Binding Notebooks}"
                          SelectedItem="{Binding SelectedNotebook}"
                          BorderThickness="0" Background="Transparent"
                          ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                          Padding="8,4">

                    <ListView.ItemContainerStyle>
                        <Style TargetType="ListViewItem">
                            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                            <Setter Property="Padding" Value="0"/>
                            <Setter Property="Margin" Value="0,2"/>
                            <Setter Property="Background" Value="Transparent"/>
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="ListViewItem">
                                        <Border Background="{TemplateBinding Background}"
                                                CornerRadius="6" Padding="2">
                                            <ContentPresenter/>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsSelected" Value="True">
                                                <Setter Property="Background" Value="#EBEBEB"/>
                                            </Trigger>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter Property="Background" Value="#F0F0F0"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </ListView.ItemContainerStyle>

                    <ListView.ItemTemplate>
                        <DataTemplate>
                            <Grid Tag="{Binding DataContext, RelativeSource={RelativeSource AncestorType=Window}}">

                                <!-- 一般顯示模式 -->
                                <TextBlock Text="{Binding Name}"
                                           FontSize="14" Padding="8,6"
                                           TextTrimming="CharacterEllipsis"
                                           Foreground="#1A1A1A"
                                           Visibility="{Binding IsEditing, Converter={StaticResource InverseBoolToVisibilityConverter}}"
                                           Tag="{Binding DataContext, RelativeSource={RelativeSource AncestorType=Window}}">
                                    <TextBlock.ContextMenu>
                                        <ContextMenu>
                                            <MenuItem Header="重新命名"
                                                      Command="{Binding PlacementTarget.Tag.EditCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                                      CommandParameter="{Binding PlacementTarget.DataContext, RelativeSource={RelativeSource AncestorType=ContextMenu}}"/>
                                            <MenuItem Header="刪除"
                                                      Command="{Binding PlacementTarget.Tag.DeleteNotebookCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                                      CommandParameter="{Binding PlacementTarget.DataContext, RelativeSource={RelativeSource AncestorType=ContextMenu}}"/>
                                        </ContextMenu>
                                    </TextBlock.ContextMenu>
                                </TextBlock>

                                <!-- 編輯模式 -->
                                <TextBox Text="{Binding EditingName, UpdateSourceTrigger=PropertyChanged}"
                                         FontSize="14" Padding="8,6" BorderThickness="0"
                                         Background="White"
                                         Visibility="{Binding IsEditing, Converter={StaticResource BoolToVisibilityConverter}}"
                                         Tag="{Binding DataContext, RelativeSource={RelativeSource AncestorType=Window}}"
                                         LostFocus="RenameTextBox_LostFocus">
                                    <TextBox.InputBindings>
                                        <KeyBinding Key="Enter"
                                                    Command="{Binding RelativeSource={RelativeSource AncestorType=TextBox}, Path=Tag.ConfirmNotebookRenameCommand}"
                                                    CommandParameter="{Binding}"/>
                                        <KeyBinding Key="Escape"
                                                    Command="{Binding RelativeSource={RelativeSource AncestorType=TextBox}, Path=Tag.CancelNotebookRenameCommand}"
                                                    CommandParameter="{Binding}"/>
                                    </TextBox.InputBindings>
                                </TextBox>
                            </Grid>
                        </DataTemplate>
                    </ListView.ItemTemplate>
                </ListView>
            </DockPanel>
        </Border>

        <!-- ===== 中間：筆記列表 ===== -->
        <Border DockPanel.Dock="Left" Width="240"
                Background="#FAFAFA"
                BorderBrush="#E8E8E8" BorderThickness="0,0,1,0">
            <DockPanel LastChildFill="True">

                <!-- + New page 按鈕 -->
                <Border DockPanel.Dock="Top"
                        BorderBrush="#E8E8E8" BorderThickness="0,0,0,1"
                        Padding="8,4">
                    <Button Command="{Binding StartAddNoteCommand}"
                            Height="36" BorderThickness="0"
                            Background="Transparent"
                            HorizontalContentAlignment="Left"
                            Cursor="Hand"
                            IsEnabled="{Binding SelectedNotebook, Converter={StaticResource NullToBoolConverter}}">
                        <Button.Content>
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="＋" FontSize="16"
                                           Foreground="#888888" Margin="4,0,8,0"
                                           VerticalAlignment="Center"/>
                                <TextBlock Text="New page" FontSize="14"
                                           Foreground="#888888"
                                           VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button.Content>
                        <Button.Style>
                            <Style TargetType="Button">
                                <Style.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter Property="Background" Value="#F0F0F0"/>
                                    </Trigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border Background="{TemplateBinding Background}"
                                        CornerRadius="6" Padding="8,4">
                                    <ContentPresenter/>
                                </Border>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>
                </Border>

                <!-- 筆記列表 -->
                <ListView ItemsSource="{Binding Notes}"
                          SelectedItem="{Binding SelectedNote}"
                          BorderThickness="0" Background="Transparent"
                          ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                          Padding="8,4">

                    <ListView.ItemContainerStyle>
                        <Style TargetType="ListViewItem">
                            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                            <Setter Property="Padding" Value="0"/>
                            <Setter Property="Margin" Value="0,2"/>
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="ListViewItem">
                                        <Border Background="{TemplateBinding Background}"
                                                CornerRadius="6" Padding="2">
                                            <ContentPresenter/>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsSelected" Value="True">
                                                <Setter Property="Background" Value="#EBEBEB"/>
                                            </Trigger>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter Property="Background" Value="#F0F0F0"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </ListView.ItemContainerStyle>

                    <ListView.ItemTemplate>
                        <DataTemplate>
                            <Grid Tag="{Binding DataContext, RelativeSource={RelativeSource AncestorType=Window}}">

                                <!-- 一般顯示模式 -->
                                <TextBlock Text="{Binding Name}"
                                           FontSize="14" Padding="8,6"
                                           TextTrimming="CharacterEllipsis"
                                           Foreground="#1A1A1A"
                                           Visibility="{Binding IsEditing, Converter={StaticResource InverseBoolToVisibilityConverter}}"
                                           Tag="{Binding DataContext, RelativeSource={RelativeSource AncestorType=Window}}">
                                    <TextBlock.ContextMenu>
                                        <ContextMenu>
                                            <MenuItem Header="刪除"
                                                      Command="{Binding PlacementTarget.Tag.DeleteNoteCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                                      CommandParameter="{Binding PlacementTarget.DataContext, RelativeSource={RelativeSource AncestorType=ContextMenu}}"/>
                                        </ContextMenu>
                                    </TextBlock.ContextMenu>
                                </TextBlock>

                                <!-- 編輯模式 -->
                                <TextBox Text="{Binding EditingName, UpdateSourceTrigger=PropertyChanged}"
                                         FontSize="14" Padding="8,6" BorderThickness="0"
                                         Background="White"
                                         Visibility="{Binding IsEditing, Converter={StaticResource BoolToVisibilityConverter}}"
                                         Tag="{Binding DataContext, RelativeSource={RelativeSource AncestorType=Window}}"
                                         LostFocus="NoteRenameTextBox_LostFocus">
                                    <TextBox.InputBindings>
                                        <KeyBinding Key="Enter"
                                                    Command="{Binding RelativeSource={RelativeSource AncestorType=TextBox}, Path=Tag.ConfirmNoteRenameCommand}"
                                                    CommandParameter="{Binding}"/>
                                        <KeyBinding Key="Escape"
                                                    Command="{Binding RelativeSource={RelativeSource AncestorType=TextBox}, Path=Tag.CancelNoteRenameCommand}"
                                                    CommandParameter="{Binding}"/>
                                    </TextBox.InputBindings>
                                </TextBox>
                            </Grid>
                        </DataTemplate>
                    </ListView.ItemTemplate>
                </ListView>
            </DockPanel>
        </Border>

        <!-- ===== 右側：編輯區 ===== -->
        <Grid Background="White">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>
            <!-- ===== 沒選筆記時的引導畫面 ===== -->
            <StackPanel Grid.RowSpan="2"
                HorizontalAlignment="Center"
                VerticalAlignment="Center"
                ZIndex="1">
                <StackPanel.Style>
                    <Style TargetType="StackPanel">
                        <Setter Property="Visibility" Value="Collapsed"/>
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding SelectedNote}" Value="{x:Null}">
                                <Setter Property="Visibility" Value="Visible"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </StackPanel.Style>
                <TextBlock Text="📝" FontSize="48"
                   HorizontalAlignment="Center"
                   Margin="0,0,0,16"/>
                <TextBlock Text="選擇一篇筆記開始編輯"
                   FontSize="16" Foreground="#9B9B9B"
                   HorizontalAlignment="Center"/>
            </StackPanel>

            <!-- 標題列 -->
            <Border Grid.Row="0"
                    BorderBrush="#E8E8E8" BorderThickness="0,0,0,1"
                    Padding="24,8">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <!-- 筆記標題 -->
                    <TextBox Grid.Column="0"
                             Text="{Binding SelectedNote.Name, UpdateSourceTrigger=PropertyChanged}"
                             TextChanged="TitleTextBox_TextChanged"
                             FontSize="20" FontWeight="Bold"
                             BorderThickness="0" Padding="0"
                             VerticalContentAlignment="Center"
                             Background="Transparent"
                             Foreground="#1A1A1A"
                             IsEnabled="{Binding SelectedNote, Converter={StaticResource NullToBoolConverter}}"/>

                    <!-- ✅ 儲存狀態取代儲存按鈕 -->
                    <TextBlock Grid.Column="1"
                               Text="{Binding SaveStatus}"
                               FontSize="12" Foreground="#9B9B9B"
                               VerticalAlignment="Center"
                               Margin="8,0"/>
                </Grid>
            </Border>

            <!-- 筆記內容 -->
            <RichTextBox Grid.Row="1"
                         x:Name="contentRichTextBox"
                         Margin="24,16"
                         FontSize="15"
                         BorderThickness="0"
                         VerticalScrollBarVisibility="Auto"
                         Foreground="#1A1A1A"
                         TextChanged="ContentRichTextBox_TextChanged"
                         IsEnabled="{Binding SelectedNote, Converter={StaticResource NullToBoolConverter}}"/>
        </Grid>

    </DockPanel>
</Window>