<Window x:Class="StockEvernote.View.NotesWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:vm="clr-namespace:StockEvernote.ViewModel"
        xmlns:converters="clr-namespace:StockEvernote.Converters"
        mc:Ignorable="d"
        d:DataContext="{d:DesignInstance Type=vm:NotesViewModel}"
        WindowStartupLocation="CenterScreen"
        PreviewMouseDown="Window_PreviewMouseDown"
        FontFamily="Microsoft JhengHei UI"
        Title="StockEvernote" Height="680" Width="1200">

    <DockPanel>

        <!-- ===== Menu ===== -->
        <Border DockPanel.Dock="Top"
                Background="White"
                BorderBrush="#E8E8E8"
                BorderThickness="0,0,0,1"
                Height="48">

            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <Menu Grid.Column="0"
                      Background="Transparent"
                      VerticalAlignment="Center"
                      Padding="8,0">
                    <MenuItem Header="📚 筆記本" Padding="8,4">
                        <MenuItem Header="新增筆記本"
                                  Command="{Binding AddNotebookCommand}"
                                  Padding="8,6"/>
                        <Separator/>
                        <MenuItem Header="同步到雲端"
                                  Command="{Binding SyncCommand}"
                                  Padding="8,6"/>
                        <Separator/>
                        <MenuItem Header="從雲端還原"
                                  Command="{Binding RestoreFromCloudCommand}"
                                  Padding="8,6"/>
                        <Separator/>
                        <MenuItem Header="退出"
                                  Click="MenuItem_Click"
                                  Padding="8,6"/>
                    </MenuItem>
                </Menu>

                <!-- 右上角登出按鈕 -->
                <Button Grid.Column="1"
                        Command="{Binding LogoutCommand}"
                        Margin="0,0,16,0"
                        Height="32" Padding="16,0"
                        VerticalAlignment="Center"
                        Cursor="Hand"
                        Foreground="White"
                        BorderThickness="0">
                    <Button.Content>
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="🚪" FontSize="13"
                                       Margin="0,0,6,0"
                                       VerticalAlignment="Center"/>
                            <TextBlock Text="登出" FontSize="13"
                                       VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button.Content>
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border Background="{TemplateBinding Background}"
                                    CornerRadius="6"
                                    Padding="{TemplateBinding Padding}">
                                <ContentPresenter HorizontalAlignment="Center"
                                                  VerticalAlignment="Center"/>
                            </Border>
                        </ControlTemplate>
                    </Button.Template>
                    <Button.Style>
                        <Style TargetType="Button">
                            <Setter Property="Background" Value="#1A1A1A"/>
                            <Style.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter Property="Background" Value="#333333"/>
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </Button.Style>
                </Button>
            </Grid>
        </Border>

        <!-- ===== 搜尋列 ===== -->
        <Border DockPanel.Dock="Top"
        Background="White"
        BorderBrush="#E8E8E8"
        BorderThickness="0,0,0,1"
        Padding="12,6">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- 搜尋輸入框 -->
                <TextBox Grid.Column="0"
                 Text="{Binding SearchKeyword, UpdateSourceTrigger=PropertyChanged}"
                 TextChanged="SearchTextBox_TextChanged"
                 FontSize="14" Padding="8,6"
                 BorderThickness="1" BorderBrush="#D0D0D0"
                 Background="#FAFAFA"
                 VerticalContentAlignment="Center">
                    <TextBox.InputBindings>
                        <KeyBinding Key="Return"
                            Command="{Binding SearchCommand}"/>
                        <KeyBinding Key="Escape"
                            Command="{Binding ClearSearchCommand}"/>
                    </TextBox.InputBindings>
                </TextBox>

                <!-- 全域/當前切換 -->
                <ToggleButton Grid.Column="1"
                      IsChecked="{Binding IsSearchGlobal}"
                      Content="{Binding IsSearchGlobal, Converter={StaticResource BoolToSearchScopeConverter}}"
                      FontSize="12" Padding="8,6" Margin="6,0,0,0"
                      BorderThickness="1" BorderBrush="#D0D0D0"
                      Background="White" Foreground="#555555"
                      Cursor="Hand"/>

                <!-- 清除按鈕 -->
                <Button Grid.Column="2"
                Command="{Binding ClearSearchCommand}"
                Content="✕" FontSize="14"
                Padding="8,6" Margin="4,0,0,0"
                BorderThickness="0" Background="Transparent"
                Foreground="#999999" Cursor="Hand"
                Visibility="{Binding IsSearchMode, Converter={StaticResource BoolToVisibilityConverter}}"/>
            </Grid>
        </Border>

        <!-- ===== 搜尋結果面板（覆蓋在筆記本+筆記列表上方） ===== -->
        <!-- 放在左側筆記本列表的 Border 之前 -->
        <Border DockPanel.Dock="Left" Width="440"
        Background="White"
        BorderBrush="#E8E8E8" BorderThickness="0,0,1,0"
        Visibility="{Binding IsSearchMode, Converter={StaticResource BoolToVisibilityConverter}}">
            <DockPanel>
                <Border DockPanel.Dock="Top" Padding="12,8"
                BorderBrush="#E8E8E8" BorderThickness="0,0,0,1">
                    <TextBlock FontSize="13" Foreground="#888888">
                <Run Text="搜尋結果："/>
                <Run Text="{Binding SearchResults.Count, Mode=OneWay}"/>
                <Run Text=" 筆"/>
                    </TextBlock>
                </Border>

                <ListView ItemsSource="{Binding SearchResults}"
                  SelectedItem="{Binding SelectedSearchResult}"
                  BorderThickness="0" Background="Transparent"
                  ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                  Padding="8,4">
                    <ListView.ItemTemplate>
                        <DataTemplate>
                            <StackPanel Margin="4,6">
                                <TextBlock Text="{Binding NoteName}"
                                   FontSize="14" FontWeight="SemiBold"
                                   Foreground="#1A1A1A"
                                   TextTrimming="CharacterEllipsis"/>
                                <TextBlock Text="{Binding NotebookName}"
                                   FontSize="11" Foreground="#999999"
                                   Margin="0,2,0,0"/>
                                <TextBlock Text="{Binding MatchSnippet}"
                                   FontSize="12" Foreground="#666666"
                                   TextWrapping="Wrap" MaxHeight="40"
                                   Margin="0,4,0,0"/>
                            </StackPanel>
                        </DataTemplate>
                    </ListView.ItemTemplate>
                </ListView>
            </DockPanel>
        </Border>

        <!-- ===== StatusBar ===== -->
        <StatusBar DockPanel.Dock="Bottom"
                   Background="#F7F7F7"
                   BorderBrush="#E8E8E8" BorderThickness="0,1,0,0"
                   Height="28">
            <StatusBarItem>
                <TextBlock Text="{Binding StatusMessage}"
                           FontSize="12" Foreground="#1A1A1A"/>
            </StatusBarItem>
            <!-- ===== 正式要刪除 ===== -->
            <StatusBarItem HorizontalAlignment="Right">
                <CheckBox Content="自動同步"
                  IsChecked="{Binding IsAutoSyncEnabled}"
                  FontSize="12" Foreground="#888888"
                  VerticalContentAlignment="Center"/>
            </StatusBarItem>
            <!-- ===== 正式要刪除 ===== -->
        </StatusBar>

        <!-- ===== 左側：筆記本列表 ===== -->
        <Border DockPanel.Dock="Left" Width="200"
                Background="#F7F7F7"
                BorderBrush="#E8E8E8" BorderThickness="0,0,1,0">
            <DockPanel>

                <!-- 標題 -->
                <Border DockPanel.Dock="Top"
                        Padding="16,12"
                        BorderBrush="#E8E8E8" BorderThickness="0,0,0,1">
                    <TextBlock Text="筆記本"
                               FontSize="13" FontWeight="SemiBold"
                               Foreground="#888888"/>
                </Border>

                <!-- 筆記本列表 -->
                <ListView ItemsSource="{Binding Notebooks}"
                          SelectedItem="{Binding SelectedNotebook}"
                          BorderThickness="0" Background="Transparent"
                          ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                          Padding="8,4">

                    <ListView.ItemContainerStyle>
                        <Style TargetType="ListViewItem">
                            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                            <Setter Property="Padding" Value="0"/>
                            <Setter Property="Margin" Value="0,2"/>
                            <Setter Property="Background" Value="Transparent"/>
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="ListViewItem">
                                        <Border Background="{TemplateBinding Background}"
                                                CornerRadius="6" Padding="2">
                                            <ContentPresenter/>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsSelected" Value="True">
                                                <Setter Property="Background" Value="#EBEBEB"/>
                                            </Trigger>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter Property="Background" Value="#F0F0F0"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </ListView.ItemContainerStyle>

                    <ListView.ItemTemplate>
                        <DataTemplate>
                            <Grid Tag="{Binding DataContext, RelativeSource={RelativeSource AncestorType=Window}}">

                                <!-- 一般顯示模式 -->
                                <TextBlock Text="{Binding Name}"
                                           FontSize="14" Padding="8,6" 
                                           TextTrimming="CharacterEllipsis"
                                           Foreground="#1A1A1A"
                                           Visibility="{Binding IsEditing, Converter={StaticResource InverseBoolToVisibilityConverter}}"
                                           Tag="{Binding DataContext, RelativeSource={RelativeSource AncestorType=Window}}">
                                    <TextBlock.ContextMenu>
                                        <ContextMenu>
                                            <MenuItem Header="重新命名"
                                                      Command="{Binding PlacementTarget.Tag.EditCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                                      CommandParameter="{Binding PlacementTarget.DataContext, RelativeSource={RelativeSource AncestorType=ContextMenu}}"/>
                                            <MenuItem Header="刪除"
                                                      Command="{Binding PlacementTarget.Tag.DeleteNotebookCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                                      CommandParameter="{Binding PlacementTarget.DataContext, RelativeSource={RelativeSource AncestorType=ContextMenu}}"/>
                                        </ContextMenu>
                                    </TextBlock.ContextMenu>
                                </TextBlock>

                                <!-- 編輯模式 -->
                                <TextBox Text="{Binding EditingName, UpdateSourceTrigger=PropertyChanged}"
                                         FontSize="14" Padding="8,6" BorderThickness="0"
                                         Background="White"
                                         Visibility="{Binding IsEditing, Converter={StaticResource BoolToVisibilityConverter}}"
                                         Tag="{Binding DataContext, RelativeSource={RelativeSource AncestorType=Window}}"
                                         LostFocus="NotebookRenameTextBox_LostFocus"
                                         Loaded="AutoSelectTextBox_Loaded"
                                         IsVisibleChanged="AutoSelectTextBox_IsVisibleChanged">
                                    <TextBox.InputBindings>
                                        <KeyBinding Key="Enter"
                                                    Command="{Binding RelativeSource={RelativeSource AncestorType=TextBox}, Path=Tag.ConfirmNotebookRenameCommand}"
                                                    CommandParameter="{Binding}"/>
                                        <KeyBinding Key="Escape"
                                                    Command="{Binding RelativeSource={RelativeSource AncestorType=TextBox}, Path=Tag.CancelNotebookRenameCommand}"
                                                    CommandParameter="{Binding}"/>
                                    </TextBox.InputBindings>
                                </TextBox>
                            </Grid>
                        </DataTemplate>
                    </ListView.ItemTemplate>
                </ListView>
            </DockPanel>
        </Border>

        <!-- ===== 中間：筆記列表 ===== -->
        <Border DockPanel.Dock="Left" Width="240"
                Background="#FAFAFA"
                BorderBrush="#E8E8E8" BorderThickness="0,0,1,0">
            <DockPanel LastChildFill="True">

                <!-- + New page 按鈕 -->
                <Border DockPanel.Dock="Top"
                        BorderBrush="#E8E8E8" BorderThickness="0,0,0,1"
                        Padding="8,4">
                    <Button Command="{Binding StartAddNoteCommand}"
                            Height="36" BorderThickness="0"
                            Background="Transparent"
                            HorizontalContentAlignment="Left"
                            Cursor="Hand"
                            IsEnabled="{Binding SelectedNotebook, Converter={StaticResource NullToBoolConverter}}">
                        <Button.Content>
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="＋" FontSize="16"
                                           Foreground="#888888" Margin="4,0,8,0"
                                           VerticalAlignment="Center"/>
                                <TextBlock Text="New page" FontSize="14"
                                           Foreground="#888888"
                                           VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button.Content>
                        <Button.Style>
                            <Style TargetType="Button">
                                <Style.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter Property="Background" Value="#F0F0F0"/>
                                    </Trigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border Background="{TemplateBinding Background}"
                                        CornerRadius="6" Padding="8,4">
                                    <ContentPresenter/>
                                </Border>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>
                </Border>

                <!-- 筆記列表 -->
                <ListView ItemsSource="{Binding Notes}"
                          SelectedItem="{Binding SelectedNote}"
                          BorderThickness="0" Background="Transparent"
                          ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                          Padding="8,4">

                    <ListView.ItemContainerStyle>
                        <Style TargetType="ListViewItem">
                            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                            <Setter Property="Padding" Value="0"/>
                            <Setter Property="Margin" Value="0,2"/>
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="ListViewItem">
                                        <Border Background="{TemplateBinding Background}"
                                                CornerRadius="6" Padding="2">
                                            <ContentPresenter/>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsSelected" Value="True">
                                                <Setter Property="Background" Value="#EBEBEB"/>
                                            </Trigger>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter Property="Background" Value="#F0F0F0"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </ListView.ItemContainerStyle>

                    <ListView.ItemTemplate>
                        <DataTemplate>
                            <Grid Tag="{Binding DataContext, RelativeSource={RelativeSource AncestorType=Window}}">

                                <!-- 一般顯示模式 -->
                                <TextBlock Text="{Binding Name}"
                                           FontSize="14" Padding="8,6"
                                           TextTrimming="CharacterEllipsis"
                                           Foreground="#1A1A1A"
                                           Visibility="{Binding IsEditing, Converter={StaticResource InverseBoolToVisibilityConverter}}"
                                           Tag="{Binding DataContext, RelativeSource={RelativeSource AncestorType=Window}}">
                                    <TextBlock.ContextMenu>
                                        <ContextMenu>
                                            <MenuItem Header="刪除"
                                                      Command="{Binding PlacementTarget.Tag.DeleteNoteCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                                      CommandParameter="{Binding PlacementTarget.DataContext, RelativeSource={RelativeSource AncestorType=ContextMenu}}"/>
                                        </ContextMenu>
                                    </TextBlock.ContextMenu>
                                </TextBlock>

                                <!-- 編輯模式 -->
                                <TextBox Text="{Binding EditingName, UpdateSourceTrigger=PropertyChanged}"
                                         FontSize="14" Padding="8,6" BorderThickness="0"
                                         Background="White"
                                         Visibility="{Binding IsEditing, Converter={StaticResource BoolToVisibilityConverter}}"
                                         Tag="{Binding DataContext, RelativeSource={RelativeSource AncestorType=Window}}"
                                         LostFocus="NoteRenameTextBox_LostFocus"
                                         Loaded="AutoSelectTextBox_Loaded"
                                         IsVisibleChanged="AutoSelectTextBox_IsVisibleChanged">
                                    <TextBox.InputBindings>
                                        <KeyBinding Key="Enter"
                                                    Command="{Binding RelativeSource={RelativeSource AncestorType=TextBox}, Path=Tag.ConfirmNoteRenameCommand}"
                                                    CommandParameter="{Binding}"/>
                                        <KeyBinding Key="Escape"
                                                    Command="{Binding RelativeSource={RelativeSource AncestorType=TextBox}, Path=Tag.CancelNoteRenameCommand}"
                                                    CommandParameter="{Binding}"/>
                                    </TextBox.InputBindings>
                                </TextBox>
                            </Grid>
                        </DataTemplate>
                    </ListView.ItemTemplate>
                </ListView>
            </DockPanel>
        </Border>

        <!-- ===== 右側：編輯區 ===== -->
        <Grid Background="White" AllowDrop="True" Drop="Grid_Drop">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <!-- 標題列 -->
                <RowDefinition Height="*"/>
                <!-- 筆記內容 -->
                <RowDefinition Height="Auto"/>
                <!-- 附件列表 -->
            </Grid.RowDefinitions>
            
            <!-- ===== 沒選筆記時的引導畫面 ===== -->
            <StackPanel Grid.RowSpan="3"
                HorizontalAlignment="Center"
                VerticalAlignment="Center"
                ZIndex="1">
                <StackPanel.Style>
                    <Style TargetType="StackPanel">
                        <Setter Property="Visibility" Value="Collapsed"/>
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding SelectedNote}" Value="{x:Null}">
                                <Setter Property="Visibility" Value="Visible"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </StackPanel.Style>
                <TextBlock Text="📝" FontSize="48"
                   HorizontalAlignment="Center"
                   Margin="0,0,0,16"/>
                <TextBlock Text="選擇一篇筆記開始編輯"
                   FontSize="16" Foreground="#9B9B9B"
                   HorizontalAlignment="Center"/>
            </StackPanel>

            <!-- ===== Row 0：標題列 ===== -->

            <Border Grid.Row="0"
                    BorderBrush="#E8E8E8" BorderThickness="0,0,0,1"
                    Padding="24,8">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <!-- 筆記標題 -->
                    <TextBox Grid.Column="0"
                             Text="{Binding SelectedNote.Name, UpdateSourceTrigger=PropertyChanged}"
                             GotFocus="TitleTextBox_GotFocus"
                             LostFocus="TitleTextBox_LostFocus"
                             TextChanged="TitleTextBox_TextChanged"
                             FontSize="20" FontWeight="Bold"
                             BorderThickness="0" Padding="0"
                             VerticalContentAlignment="Center"
                             Background="Transparent"
                             Foreground="#1A1A1A"
                             IsEnabled="{Binding SelectedNote, Converter={StaticResource NullToBoolConverter}}"/>
                    
                    <!-- ✅ 儲存狀態取代儲存按鈕 -->
                    <TextBlock Grid.Column="2"
                               Text="{Binding SaveStatus}"
                               FontSize="12" Foreground="#9B9B9B"
                               HorizontalAlignment="Right"
                               VerticalAlignment="Center"
                               Margin="8,0"/>
                </Grid>
            </Border>

            <!-- 筆記內容 -->
            <RichTextBox Grid.Row="1"
                         x:Name="contentRichTextBox"
                         Margin="24,16"
                         FontSize="15"
                         BorderThickness="0"
                         VerticalScrollBarVisibility="Auto"
                         Foreground="#1A1A1A"
                         TextChanged="ContentRichTextBox_TextChanged"
                         IsEnabled="{Binding SelectedNote, Converter={StaticResource NullToBoolConverter}}"
                         
                         AllowDrop="True"
                         PreviewDragOver="ContentRichTextBox_PreviewDragOver"
                         PreviewDrop="ContentRichTextBox_PreviewDrop"/>
        
            <!-- ===== Row 2：附件列表 ===== -->
            <Border Grid.Row="2"
                    BorderBrush="#E8E8E8" BorderThickness="0,1,0,0"
                    Padding="24,8"
                    IsEnabled="{Binding Attachments.Count, Converter={StaticResource NullToBoolConverter}}">
                <DockPanel>

                    <Button DockPanel.Dock="Top"
                        Click="UploadButton_Click"
                        HorizontalAlignment="Left"
                        Background="Transparent"
                        BorderThickness="0"
                        Cursor="Hand"
                        Padding="4" Margin="-4,0,0,8"
                        ToolTip="點擊新增附件">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="📎 附件" FontSize="13" FontWeight="SemiBold" 
                                   Foreground="#888888" VerticalAlignment="Center"/>
                            <TextBlock Text="+" FontSize="14" FontWeight="Bold" 
                                   Foreground="#CCCCCC" Margin="6,-2,0,0" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>

                    <ItemsControl ItemsSource="{Binding Attachments}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Padding="8,6" Margin="0,2" CornerRadius="4"
                                        Background="#F7F7F7" Cursor="Hand">
                                    <Border.InputBindings>
                                        <MouseBinding MouseAction="LeftDoubleClick"
                                          Command="{Binding DataContext.OpenAttachmentCommand,
                                                    RelativeSource={RelativeSource AncestorType=Window}}"
                                          CommandParameter="{Binding}"/>
                                    </Border.InputBindings>
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>

                                        <!-- 圖示 -->
                                        <TextBlock Grid.Column="0" FontSize="16"
                                                   VerticalAlignment="Center" Margin="0,0,8,0"
                                                   Text="{Binding IsImage,
                                                          Converter={StaticResource BoolToAttachmentIconConverter}}"/>

                                        <!-- 檔名 -->
                                        <TextBlock Grid.Column="1"
                                                   Text="{Binding FileName}"
                                                   FontSize="13" Foreground="#1A1A1A"
                                                   VerticalAlignment="Center"
                                                   TextTrimming="CharacterEllipsis"/>

                                        <!-- 大小 -->
                                        <TextBlock Grid.Column="2"
                                                   Text="{Binding FileSize,
                                                          Converter={StaticResource FileSizeConverter}}"
                                                   FontSize="12" Foreground="#999999"
                                                   VerticalAlignment="Center" Margin="12,0"/>

                                        <!-- 刪除按鈕 -->
                                        <Button Grid.Column="3"
                                                Command="{Binding DataContext.DeleteAttachmentCommand,
                                                          RelativeSource={RelativeSource AncestorType=Window}}"
                                                CommandParameter="{Binding}"
                                                Content="✕" FontSize="12"
                                                Padding="4,2" BorderThickness="0"
                                                Background="Transparent" Foreground="#CCCCCC"
                                                Cursor="Hand"/>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </DockPanel>
            </Border>
        </Grid>
    </DockPanel>
</Window>